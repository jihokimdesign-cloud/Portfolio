        <p class="ar-sub sr">Research and prototyping at the intersection of augmented reality and human interaction.</p>
      </div>
    </div>
    <div class="ar-grid">
      <div class="ar-card sr">
        <div class="ar-card-visual" style="background:#0c1a2e">
          <img src="Sub_proj/CookAR_gif.webp" alt="CookAR">
        </div>
        <h3 class="ar-card-title">CookAR</h3>
        <p class="ar-card-desc">An AR system with real-time object affordance augmentations to support safe and efficient interactions with kitchen tools.</p>
        <div class="ar-card-tags">
          <span class="ar-tag">AR/VR</span>
          <span class="ar-tag">Accessibility</span>
          <span class="ar-tag award">UIST 2024 Best Paper &#127942;</span>
        </div>
      </div>
      <div class="ar-card sr">
        <div class="ar-card-visual" style="background:#1a1a2e">
          <img src="Sub_proj/XR_gif.png" alt="XR Furniture Shopping">
        </div>
        <h3 class="ar-card-title">Create XR Applications for Furniture Shopping</h3>
        <p class="ar-card-desc">Investigating user engagement with 3D furniture representations in extended reality shopping applications.</p>
        <div class="ar-card-tags">
          <span class="ar-tag">Retail</span>
          <span class="ar-tag">XR</span>
          <span class="ar-tag published">Medium Published &#9997;&#127995;</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- AI Lab -->
<section id="ai-lab" class="ai-section">
  <div class="ai-inner">
    <p class="ai-label sr">AI Lab</p>
    <h2 class="ai-title sr">AI, Live.</h2>
    <p class="ai-sub sr">Three experiments running entirely in your browser. No servers — just your camera, your drawings, and a neural network.</p>

    <div class="demo-grid">
      <div class="demo-card sr" data-mode="hands">
        <div class="demo-thumb" style="background:#0a0a0a">
          <video src="Sub_proj/flower_bloom.mp4" muted autoplay loop playsinline style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0"></video>
        </div>
        <div class="demo-info">
          <span class="demo-tag">MediaPipe &middot; Gesture</span>
          <h3 class="demo-card-title">Bloom Garden</h3>
          <p class="demo-card-desc">Open your hand and watch flowers bloom from your fingertips.</p>
        </div>
      </div>
      <div class="demo-card sr" data-mode="face">
        <div class="demo-thumb" style="background:#0a0a0a">
          <video src="Sub_proj/fingerspell_demo.mov" muted autoplay loop playsinline style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0"></video>
        </div>
        <div class="demo-info">
          <span class="demo-tag">MediaPipe &middot; Gesture</span>
          <h3 class="demo-card-title">Finger Spell</h3>
          <p class="demo-card-desc">Spell out sentences with hand signs — letter by letter.</p>
        </div>
      </div>
      <div class="demo-card sr" data-mode="sketch">
        <div class="demo-thumb" style="background:#0a0a0a">
          <video src="Sub_proj/AIlab_3_demo.mov" muted autoplay loop playsinline style="width:100%;height:100%;object-fit:cover;position:absolute;inset:0"></video>
        </div>
        <div class="demo-info">
          <span class="demo-tag">Canvas &middot; Symmetry</span>
          <h3 class="demo-card-title">Kaleidoscope</h3>
          <p class="demo-card-desc">Draw once, mirror eight times &mdash; create mandalas in seconds.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Modal -->
<div class="modal-overlay" id="demoModal">
  <div class="modal-box">
    <button class="modal-close" id="modalClose">&#10005;</button>
    <div class="modal-head">
      <h3 class="modal-title" id="modalTitle"></h3>
      <p class="modal-desc" id="modalDesc"></p>
    </div>

    <!-- Camera (hands & face) -->
    <div class="camera-wrap" id="cameraWrap">
      <video id="webcam" playsinline autoplay muted></video>
      <canvas id="outputCanvas"></canvas>
      <div class="camera-prompt" id="cameraPrompt">
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,.2)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="18" rx="4"/><circle cx="12" cy="12" r="3"/></svg>
        <p style="color:var(--dark-muted);font-size:13px" id="promptText">Show your hand to the camera</p>
        <button class="start-btn" id="startBtn">Start Camera</button>
      </div>
      <div class="model-loading" id="modelLoading">
        <div class="spinner"></div>
        <p style="color:var(--dark-muted);font-size:12px" id="loadingText">Loading AI model...</p>
      </div>
    </div>

    <!-- Sketch canvas -->
    <div class="sketch-wrap" id="sketchWrap">
      <canvas id="sketchCanvas" width="420" height="315"></canvas>
    </div>
    <div class="sketch-tools" id="sketchTools" style="display:none">
      <button class="sketch-btn" id="undoBtn">Undo</button>
      <button class="sketch-btn" id="clearBtn">Clear</button>
    </div>

    <div id="errorMsg" class="error-msg" style="display:none"></div>

    <!-- Results: Hands (Bloom Garden) -->
    <div class="result-area" id="resultHands" style="display:none">
      <div class="bloom-label" id="bloomLabel">Show your hand to plant...</div>
      <div class="bloom-sub" id="bloomSub">Open palm = full bloom &middot; Fist = seed</div>
      <button class="bloom-clear" id="clearGardenBtn">Clear Garden</button>
    </div>

    <!-- Results: Face (Finger Spell) -->
    <div class="result-area" id="resultFace" style="display:none">
      <div class="spell-phrase" id="spellPhrase"></div>
      <div class="spell-guide" id="spellGuide"></div>
      <div class="spell-status" id="spellStatus">Waiting...</div>
      <button class="sign-next" id="signNextBtn">Next Phrase &rarr;</button>
    </div>

    <!-- Results: Sketch (Kaleidoscope) -->
    <div class="result-area" id="resultSketch" style="display:none">
      <div class="result-label" id="sketchLabel">Draw to create a mandala</div>
      <div class="kaleid-tools" id="kaleidTools">
        <button class="kaleid-color active" data-color="#F472B6" style="background:#F472B6" title="Pink"></button>
        <button class="kaleid-color" data-color="#38BDF8" style="background:#38BDF8" title="Sky"></button>
        <button class="kaleid-color" data-color="#A78BFA" style="background:#A78BFA" title="Purple"></button>
        <button class="kaleid-color" data-color="#4ADE80" style="background:#4ADE80" title="Green"></button>
        <button class="kaleid-color" data-color="rainbow" style="background:conic-gradient(#F472B6,#FB923C,#FBBF24,#4ADE80,#38BDF8,#A78BFA,#F472B6)" title="Rainbow"></button>
      </div>
    </div>
  </div>
</div>

